# Server – Comic Search uses Superhero API (free, no key): https://akabab.github.io/superhero-api/api/

# Server – MongoDB (optional; defaults to localhost)
# MONGODB_URI=mongodb://localhost/comicSpaceDB
# PORT=3001

# Client – only needed when building for production (e.g. GitHub Pages) to point to your Render API
# REACT_APP_GRAPHQL_URI=https://your-app.onrender.com/graphql
# REACT_APP_GRAPHQL_WS_URI=wss://your-app.onrender.com/graphql
